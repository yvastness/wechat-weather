/* detail.wxss */

.container {
    height: 100vh;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    flex-direction: column;
}

/* 顶部城市信息 */
.header {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    padding: 20rpx 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
    position: relative;
    overflow: hidden;
}

.header-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 100%);
    z-index: -1;
}

.city-info {
    display: flex;
    align-items: center;
}

.city-name {
    font-size: 36rpx;
    font-weight: bold;
    color: #fff;
    text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.back-icon {
    width: 60rpx;
    height: 60rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    transition: all 0.3s ease;
}

.back-icon:active {
    transform: scale(0.9);
    background: rgba(255, 255, 255, 0.2);
}

.back-text {
    font-size: 36rpx;
    color: #fff;
    line-height: 1;
}

/* 日期信息 */
.date {
    padding-top: 0rpx;
    margin-top: 0rpx;
    color: #fff;
}

/* 白天夜晚天气 */
.day-desc {
    font-size: 25rpx;
    color: #fff;
    margin-top: -20rpx;
}

.day-night {
    margin: 30rpx 0 50rpx 0;
    display: flex;
    flex-direction: row;
    align-items: center;
}

.day-night .split {
    border: none;
    border-left: 1rpx dashed rgba(255, 255, 255, 0.5);
    height: 80rpx;
    width: 0rpx;
    padding: 0;
    margin: 15rpx 15rpx 0 15rpx;
}

.today {
    padding-top: 20rpx;
    padding: 40rpx 30rpx;
    position: relative;
}

.today .weather {
    padding-top: 20rpx;
    padding-left: 0rpx;
}

.today .weather .icon {
    margin: 0 10rpx;
    width: 100rpx;
    height: 100rpx;
}

.today .weather .desc {
    margin: 0 10rpx;
    float: right;
    width: 140rpx;
    color: #fff;
}

.today .weather .desc text {
    color: #fff;
}

/* life 生活指数 */

.card-list {
    margin-top: 30rpx;
}

.card {
    margin-top: 20rpx;
    margin-left: 20rpx;
    margin-right: 20rpx;
    color: #404040;
    background: #fff;
    border-radius: 30rpx;
    padding: 30rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.card .title {
    display: block;
    text-align: center;
    padding-bottom: 5px;
    margin: 0 100rpx 5px;
    font-size: 32rpx;
    font-weight: bold;
    color: #333;
    border-bottom: 1rpx solid #f0f0f0;
}

.life .item {
    display: inline-block;
    width: 50%;
}

.life .item .line {
    margin: 10rpx;
    padding: 20rpx;
    border-radius: 20rpx;
    border: 1px solid #e0e0e0;
    display: flex;
    flex-direction: row;
    align-items: center;
    background: #f8f8f8;
}

.life .item .icon {
    width: 48rpx;
    height: 48rpx;
    margin: 0 15rpx;
}

.life .item .name, .life .item .desc {
    font-size: 25rpx;
    line-height: 48rpx;
    padding-top: 5rpx;
    color: #333;
}

.life .item .desc {
    color: #666;
}

.life .item .desc text {
    font-size: 20rpx;
    line-height: 25rpx;
    margin-left: 20rpx;
    margin-top: 5rpx;
    color: #404040;
}

.life .item .temperature {
    font-size: 28rpx;
    line-height: 60rpx;
    margin-left: 80rpx;
    padding-top: 5rpx;
    height: 500rpx;
}